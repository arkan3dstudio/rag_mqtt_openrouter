# =========================
# OpenRouter
# =========================
OPENROUTER_API_KEY=isi_api_key_openrouter_baru
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_JSON_MODE=true
OPENROUTER_TIMEOUT_SECONDS=40
SITE_URL=http://localhost:8501
SITE_NAME=SULTANI RAG MQTT

# =========================
# RAG
# =========================
TOP_K=5
MIN_SCORE=0.05
CHUNK_SIZE=900
CHUNK_OVERLAP=150
AUTO_REBUILD_INDEX=true
TFIDF_MAX_FEATURES=100000
TFIDF_NGRAM_MAX=2
ENABLE_QUERY_EXPANSION=true
RAG_MAX_ANSWER_TOKENS=1200
RAG_TEMPERATURE=0.2
RAG_OUTPUT_MODE=hybrid
RAG_REQUIRE_LLM_SUCCESS=true
RAG_REQUIRE_RELEVANT_SOURCES=true
RAG_FALLBACK_ON_LLM_TIMEOUT=true
CHAT_MAX_SENSOR_AGE_SECONDS=1800

# =========================
# MQTT Broker
# =========================
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=sultani_rag_mqtt_server_001
MQTT_KEEPALIVE=60

# legacy:
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-telemetry
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-result
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-feedback
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-chat
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-chat-result
MQTT_TOPIC_STYLE=legacy
MQTT_TOPIC_NAMESPACE=pkmunimed
MQTT_PROJECT_SLUG=SmartSoilsense-BIMA

QOS=1
PUBLISH_RETAIN=false
MQTT_TLS_ENABLED=false
MQTT_TLS_INSECURE=false
MAX_CONCURRENCY=5
WORKER_COUNT=3
QUEUE_MAXSIZE=1000
MQTT_MAX_MESSAGES_PER_MINUTE=2
MQTT_CHAT_MAX_MESSAGES_PER_MINUTE=6
MQTT_RATE_LIMIT_SCOPE=device
MQTT_PROCESSING_TIMEOUT_SECONDS=90
MQTT_MAX_PAYLOAD_BYTES=16384
MQTT_CHAT_MAX_QUESTION_CHARS=1000
MQTT_DUPLICATE_WINDOW_SECONDS=10

# =========================
# Defaults
# =========================
DEFAULT_CROP=padi
DEFAULT_GROWTH_STAGE=vegetatif
DEFAULT_FIELD_ID=lahan_1
DEFAULT_BLOCK_ID=blok_a

# =========================
# Web/debug output
# =========================
WEB_OUTPUT_ENABLED=true
WEB_OUTPUT_DIR=web_data
WEB_OUTPUT_BASENAME=latest
WEB_OUTPUT_PER_DEVICE=true

# =========================
# Validation assumptions
# =========================
ASSUME_DEVICE_SENSOR_CALIBRATED=true
ASSUME_SOIL_TEST_VALIDATED=false
FIELD_VALIDATION_NOTE=Sensor dikalibrasi langsung pada perangkat sebelum pengiriman telemetry.
