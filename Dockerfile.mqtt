FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN python -m compileall app mqtt_main.py mqtt_handler.py mqtt_processor.py mqtt_config.py logging_setup.py build_index.py offline_eval.py

CMD ["python", "mqtt_main.py"]
