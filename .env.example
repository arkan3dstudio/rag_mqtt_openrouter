# =========================
# OpenRouter Configuration
# =========================
OPENROUTER_API_KEY="masukan_token_openrouter_kamu"
OPENROUTER_MODEL=qwen/qwen3-14b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SITE_URL=http://localhost:8501
SITE_NAME=RAG PDF OpenRouter MQTT Agronomi

# =========================
# RAG Parameter
# =========================
TOP_K=3
MIN_SCORE=0.05
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RAG_MAX_ANSWER_TOKENS=450
RAG_TEMPERATURE=0.3
RAG_LANGUAGE=id
RAG_ANSWER_STYLE=detail_terstruktur

# Otomatis rebuild index jika PDF, chunk config, atau manifest dokumen berubah.
AUTO_REBUILD_INDEX=true

# TF-IDF lebih kuat untuk frasa agronomi seperti "pupuk nitrogen" dan "fase vegetatif".
TFIDF_MAX_FEATURES=100000
TFIDF_NGRAM_MAX=2
ENABLE_QUERY_EXPANSION=true

# Dibaca oleh mqtt_processor lewat app.config.settings.
RAG_OUTPUT_MODE=hybrid
LLM_TIMEOUT_SECONDS=45
LLM_MIN_INTERVAL_SECONDS=300
RAG_CONFIDENCE_REFERENCE_SCORE=0.65
RAG_ANSWER_CACHE_MAX_ITEMS=500
OPENROUTER_TIMEOUT_SECONDS=40
OPENROUTER_JSON_MODE=false
RAG_REQUIRE_LLM_SUCCESS=true
RAG_REQUIRE_RELEVANT_SOURCES=true
RAG_FALLBACK_ON_LLM_TIMEOUT=true
CHAT_MAX_SENSOR_AGE_SECONDS=1800

# Validasi lapang tanpa menambah payload telemetry.
# Gunakan true bila sensor dikalibrasi langsung di perangkat sebelum kirim MQTT.
ASSUME_DEVICE_SENSOR_CALIBRATED=true
ASSUME_SOIL_TEST_VALIDATED=false
FIELD_VALIDATION_NOTE=Sensor dikalibrasi langsung pada perangkat sebelum pengiriman telemetry.

# =========================
# MQTT Broker Configuration
# =========================
MQTT_BROKER=isi_broker_mqtt
MQTT_PORT=1883
MQTT_USERNAME=isi_username_mqtt
MQTT_PASSWORD=isi_password_mqtt
MQTT_CLIENT_ID=rag_mqtt_server_001
MQTT_KEEPALIVE=60

# =========================
# MQTT Topic Configuration
# =========================
# legacy = cocok dengan format Anda saat ini:
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-telemetry
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-result
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-feedback
# path = format rapi untuk versi berikutnya:
#   pkmunimed/{device_id}/SmartSoilsense-BIMA/telemetry
#   pkmunimed/{device_id}/SmartSoilsense-BIMA/result
#   pkmunimed/{device_id}/SmartSoilsense-BIMA/feedback
MQTT_TOPIC_STYLE=legacy
MQTT_TOPIC_NAMESPACE=pkmunimed
MQTT_PROJECT_SLUG=SmartSoilsense-BIMA
TOPIC_TELEMETRY=pkmunimed/+/SmartSoilsense-BIMA-telemetry

# Override manual jika ingin pakai format lama agri/v1:
# TOPIC_TELEMETRY=agri/v1/+/rag/telemetry
# TOPIC_RESPONSE=agri/v1/{device_id}/rag/response
# TOPIC_FEEDBACK=agri/v1/{device_id}/rag/feedback

# Chatbot MQTT:
# App kirim pertanyaan ke TOPIC_CHAT, server jawab ke TOPIC_CHAT_RESPONSE.
# Legacy default:
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-chat
#   pkmunimed/{device_id}/SmartSoilsense-BIMA-chat-result
# TOPIC_CHAT=pkmunimed/+/SmartSoilsense-BIMA-chat
# TOPIC_CHAT_RESPONSE=pkmunimed/{device_id}/SmartSoilsense-BIMA-chat-result

# =========================
# MQTT Runtime Configuration
# =========================
QOS=1
PUBLISH_RETAIN=false
MQTT_RECONNECT_DELAY_MIN=1
MQTT_RECONNECT_DELAY_MAX=30
MQTT_TLS_ENABLED=false
# MQTT_TLS_CA_CERT=/path/to/ca.crt
MQTT_TLS_INSECURE=false
MAX_CONCURRENCY=5
WORKER_COUNT=3
QUEUE_MAXSIZE=1000

# Batasi telemetry masuk agar satu device/topic tidak memenuhi queue RAG/LLM.
# 0 = nonaktif. Scope: device, topic, atau device_topic.
MQTT_MAX_MESSAGES_PER_MINUTE=2
MQTT_CHAT_MAX_MESSAGES_PER_MINUTE=6
MQTT_RATE_LIMIT_SCOPE=device

# Batas waktu total pemrosesan satu telemetry di worker MQTT.
# Harus lebih besar dari LLM_TIMEOUT_SECONDS karena mencakup validasi, retrieval, dan publish.
MQTT_PROCESSING_TIMEOUT_SECONDS=75

# Monitoring queue. Jika queue mencapai warn size, server tulis WARNING.
MQTT_QUEUE_WARN_SIZE=20
MQTT_QUEUE_LOG_INTERVAL_SECONDS=30
MQTT_MAX_PAYLOAD_BYTES=16384
MQTT_CHAT_MAX_QUESTION_CHARS=1000
MQTT_DUPLICATE_WINDOW_SECONDS=10

# =========================
# Default Context untuk RAG Sensor
# Bisa dioverride lewat payload device: crop, growth_stage, field_id, block_id.
# =========================
DEFAULT_CROP=padi
DEFAULT_GROWTH_STAGE=vegetatif
DEFAULT_FIELD_ID=lahan_1
DEFAULT_BLOCK_ID=blok_a

# =========================
# Optional latest JSON file output
# =========================
WEB_OUTPUT_ENABLED=true
WEB_OUTPUT_DIR=web_data
WEB_OUTPUT_BASENAME=latest
WEB_OUTPUT_PER_DEVICE=true
